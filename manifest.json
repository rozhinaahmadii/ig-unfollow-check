{
  "manifest_version": 3,
  "name": "IG Web Unfollow Checker",
  "version": "1.0.0",
  "description": "Analyze account connections and identify non-reciprocal updates directly on-page.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://www.instagram.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}